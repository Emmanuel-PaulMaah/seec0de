{
  "name": "seec0de",
  "version": "3.5.0",
  "description": "Write natural instructions, see pseudocode & code. Paste code, see explanations.",
  "main": "src/main/main.js",
  "author": "Emmanuel Paulmaah",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"webpack serve --config webpack.renderer.js\" \"wait-on http://localhost:9000 && electron .\"",
    "build:renderer": "webpack --config webpack.renderer.js --mode production",
    "dist:win": "npm run build:renderer && electron-builder --win",
    "release:win": "npm run build:renderer && electron-builder --win --publish always"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "lucide-react": "^1.9.0",
    "monaco-editor": "^0.45.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "@babel/preset-react": "^7.22.0",
    "babel-loader": "^9.1.0",
    "concurrently": "^8.2.0",
    "css-loader": "^6.8.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3",
    "html-webpack-plugin": "^5.5.0",
    "style-loader": "^3.3.0",
    "wait-on": "^7.2.0",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.0",
    "webpack-dev-server": "^4.15.0"
  },
  "build": {
    "appId": "com.emmanuelpaulmaah.seec0de",
    "productName": "seec0de",
    "files": [
      "src/main/**/*",
      "dist/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Emmanuel-PaulMaah",
        "repo": "seec0de",
        "releaseType": "release"
      }
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false
    }
  }
}
